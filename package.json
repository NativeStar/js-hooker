{
  "name": "js-hooker",
  "private": false,
  "version": "1.0.0",
  "description": "一个轻量、简洁的 适用于浏览器环境的JavaScript Hook库 A lightweight JavaScript hooking library for browser environments",
  "license": "ISC",
  "author": "NativeStar",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": ["hook", "javascript", "code-injection","browser","esm","aop","injection","patch","debug","hack"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:js": "esbuild index.ts --bundle --format=esm --platform=browser --target=es2022 --outfile=dist/index.js",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run build:js && npm run build:types"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
